# Авито OAuth2
AVITO_CLIENT_ID=your_client_id
AVITO_CLIENT_SECRET=your_client_secret
AVITO_USER_ID=your_avito_user_id

# Weeek
WEEEK_API_TOKEN=your_bearer_token
WEEEK_PROJECT_ID=
WEEEK_BOARD_ID=
WEEEK_BOARD_COLUMN_ID=

# Сервер
PORT=3000
HOST=0.0.0.0
WEBHOOK_PATH=/webhook/avito

# База данных PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/avito_weeek

# Polling интервалы (мс)
CALLS_POLL_INTERVAL_MS=300000
